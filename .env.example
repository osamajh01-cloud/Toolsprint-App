# ToolSprint — environment variables
#
# Copy this file to `.env.local` for local development.
# On Vercel, set these under Project → Settings → Environment Variables.
#
# NOTE: `NEXT_PUBLIC_` variables are exposed to the browser. Never put
# secrets in a NEXT_PUBLIC_ variable.

# Canonical site URL. Used for absolute metadata URLs (Open Graph),
# and later for the sitemap and JSON-LD. Falls back to the Vercel
# preview URL placeholder defined in config/site.ts if unset.
NEXT_PUBLIC_SITE_URL=https://toolsprint.vercel.app

# --- Reserved for future milestones (do not set yet) ---
# DATABASE_URL=            # Milestone: auth/subscriptions (Prisma + Postgres)
# NEXTAUTH_SECRET=         # Milestone: authentication
# STRIPE_SECRET_KEY=       # Milestone: subscriptions
# STRIPE_WEBHOOK_SECRET=   # Milestone: subscriptions
